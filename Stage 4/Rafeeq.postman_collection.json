{
  "info": {
    "_postman_id": "rafeeq-api-2026-06",
    "name": "Rafeeq API",
    "description": "Complete API collection for Rafeeq (rafeeqsa.me) — a companion-on-demand platform for seniors.\n\n**Base URL:** Set `baseUrl` variable to `http://localhost:3000` for local dev or `https://rafeeqsa.me` for production.\n\n**Auth:** Collection-level Bearer auth uses `{{accessToken}}`. Run `Auth → Login` first to populate it (manually copy the response).\n\n**Conventions:** All API routes are under `/api/*`. Only `/webhooks/*` lives at the root.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "requestId", "value": "1", "type": "string" },
    { "key": "userId", "value": "1", "type": "string" },
    { "key": "companionId", "value": "2", "type": "string" },
    { "key": "docId", "value": "1", "type": "string" },
    { "key": "docTypeId", "value": "1", "type": "string" },
    { "key": "rateId", "value": "1", "type": "string" },
    { "key": "addressId", "value": "1", "type": "string" },
    { "key": "beneficiaryId", "value": "1", "type": "string" },
    { "key": "withdrawalId", "value": "1", "type": "string" },
    { "key": "ticketId", "value": "1", "type": "string" },
    { "key": "deviceToken", "value": "sample-fcm-token", "type": "string" }
  ],
  "item": [
    {
      "name": "Public",
      "description": "Endpoints accessible without authentication.",
      "item": [
        {
          "name": "Health check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/health", "host": ["{{baseUrl}}"], "path": ["api", "health"] },
            "description": "Returns service status and current timestamp. Use for uptime monitoring."
          }
        },
        {
          "name": "Public runtime config",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/config/public", "host": ["{{baseUrl}}"], "path": ["api", "config", "public"] },
            "description": "Returns runtime config values that are safe to expose to the SPA (currently: google_maps_api_key)."
          }
        }
      ]
    },
    {
      "name": "Reference Data",
      "description": "Read-only lookup data used by the request flow.",
      "item": [
        {
          "name": "List service types",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/reference/service-types", "host": ["{{baseUrl}}"], "path": ["api", "reference", "service-types"] },
            "description": "Returns the catalog of companion service types (medical visit, in-home, shopping, etc.)."
          }
        },
        {
          "name": "List health conditions",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/reference/health-conditions", "host": ["{{baseUrl}}"], "path": ["api", "reference", "health-conditions"] },
            "description": "Returns the catalog of health conditions used during request creation."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "description": "Registration, login, and token management.",
      "item": [
        {
          "name": "Register client",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"first_name\": \"Ahmad\",\n  \"last_name\": \"AlSaleh\",\n  \"gender\": \"male\",\n  \"date_of_birth\": \"1990-05-12\",\n  \"mobile\": \"0512345678\",\n  \"email\": \"ahmad@example.com\",\n  \"password\": \"Secret123\",\n  \"confirm_password\": \"Secret123\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "description": "Creates a new client account. Sends an OTP to the email for verification. Rate-limited."
          }
        },
        {
          "name": "Register companion",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"first_name\": \"Khalid\",\n  \"last_name\": \"AlOtaibi\",\n  \"gender\": \"male\",\n  \"date_of_birth\": \"1988-03-22\",\n  \"mobile\": \"0598765432\",\n  \"email\": \"khalid@example.com\",\n  \"password\": \"Secret123\",\n  \"confirm_password\": \"Secret123\",\n  \"terms_accepted\": true\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/companions/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "companions", "register"] },
            "description": "Creates a new companion account. Requires terms acceptance. Companion stays inactive until admin approval."
          }
        },
        {
          "name": "Verify email (OTP)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"ahmad@example.com\",\n  \"otp\": \"123456\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/verify-email", "host": ["{{baseUrl}}"], "path": ["api", "auth", "verify-email"] },
            "description": "Verifies the email OTP received after registration. Activates the account."
          }
        },
        {
          "name": "Resend OTP",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"ahmad@example.com\",\n  \"purpose\": \"email_verification\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/resend-otp", "host": ["{{baseUrl}}"], "path": ["api", "auth", "resend-otp"] },
            "description": "Resends an OTP. purpose: email_verification | login | password_reset. Rate-limited."
          }
        },
        {
          "name": "Forgot password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"ahmad@example.com\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["api", "auth", "forgot-password"] },
            "description": "Sends a password-reset OTP to the email. Returns the same response whether the email exists or not (prevents user enumeration)."
          }
        },
        {
          "name": "Reset password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"ahmad@example.com\",\n  \"otp\": \"123456\",\n  \"new_password\": \"NewSecret123\",\n  \"confirm_password\": \"NewSecret123\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/reset-password", "host": ["{{baseUrl}}"], "path": ["api", "auth", "reset-password"] },
            "description": "Verifies the password-reset OTP and sets a new password. Invalidates all refresh tokens for the user."
          }
        },
        {
          "name": "Login (email)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"ahmad@example.com\",\n  \"password\": \"Secret123\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "description": "Logs in with email + password. Returns access_token + refresh_token. Use email XOR mobile (exactly one)."
          }
        },
        {
          "name": "Login (mobile)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"mobile\": \"0512345678\",\n  \"password\": \"Secret123\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "description": "Logs in with mobile + password. Returns access_token + refresh_token."
          }
        },
        {
          "name": "Refresh access token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api", "auth", "refresh"] },
            "description": "Issues a new access token using the refresh token."
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/logout", "host": ["{{baseUrl}}"], "path": ["api", "auth", "logout"] },
            "description": "Revokes the refresh token (single-device logout)."
          }
        },
        {
          "name": "Get my profile",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "auth", "me"] },
            "description": "Returns the authenticated user's profile."
          }
        },
        {
          "name": "Mint Firebase custom token",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/auth/firebase-token", "host": ["{{baseUrl}}"], "path": ["api", "auth", "firebase-token"] },
            "description": "Issues a short-lived Firebase custom token so the client can sign in to Firebase (used for Firestore chat + lifecycle events subscriptions)."
          }
        }
      ]
    },
    {
      "name": "Me - Devices",
      "description": "Register / unregister push notification devices.",
      "item": [
        {
          "name": "Register device",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"{{deviceToken}}\",\n  \"platform\": \"web\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/me/devices", "host": ["{{baseUrl}}"], "path": ["api", "me", "devices"] },
            "description": "Registers an FCM device token for push notifications. platform: ios | android | web."
          }
        },
        {
          "name": "Unregister device",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/me/devices/{{deviceToken}}", "host": ["{{baseUrl}}"], "path": ["api", "me", "devices", "{{deviceToken}}"] },
            "description": "Removes a registered FCM token (logout from a specific device)."
          }
        }
      ]
    },
    {
      "name": "Me - Addresses",
      "description": "Client's saved pickup addresses (max 20). Used to autofill the request form.",
      "item": [
        {
          "name": "List addresses",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/me/addresses", "host": ["{{baseUrl}}"], "path": ["api", "me", "addresses"] }
          }
        },
        {
          "name": "Create address",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"label\": \"Home\",\n  \"city\": \"Riyadh\",\n  \"district\": \"Al Olaya\",\n  \"street\": \"King Fahd Rd\",\n  \"building_number\": \"123\",\n  \"apartment_number\": \"5A\",\n  \"short_address\": \"Olaya Tower\",\n  \"lat\": 24.7136,\n  \"lng\": 46.6753\n}" },
            "url": { "raw": "{{baseUrl}}/api/me/addresses", "host": ["{{baseUrl}}"], "path": ["api", "me", "addresses"] }
          }
        },
        {
          "name": "Update address",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"label\": \"Office\",\n  \"city\": \"Riyadh\",\n  \"district\": \"Al Malqa\",\n  \"lat\": 24.8000,\n  \"lng\": 46.6500\n}" },
            "url": { "raw": "{{baseUrl}}/api/me/addresses/{{addressId}}", "host": ["{{baseUrl}}"], "path": ["api", "me", "addresses", "{{addressId}}"] }
          }
        },
        {
          "name": "Delete address",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/me/addresses/{{addressId}}", "host": ["{{baseUrl}}"], "path": ["api", "me", "addresses", "{{addressId}}"] }
          }
        }
      ]
    },
    {
      "name": "Me - Beneficiaries",
      "description": "Beneficiaries that the client requests services on behalf of (e.g., parents).",
      "item": [
        {
          "name": "List beneficiaries",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/me/beneficiaries", "host": ["{{baseUrl}}"], "path": ["api", "me", "beneficiaries"] }
          }
        },
        {
          "name": "Create beneficiary",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"full_name\": \"Saleh AlSaleh\",\n  \"age\": 72,\n  \"mobile\": \"0511112222\",\n  \"gender\": \"male\",\n  \"kinship\": \"father\",\n  \"health_condition_ids\": [1, 2]\n}" },
            "url": { "raw": "{{baseUrl}}/api/me/beneficiaries", "host": ["{{baseUrl}}"], "path": ["api", "me", "beneficiaries"] },
            "description": "kinship must be one of: son, daughter, father, mother, brother, sister, husband, wife, grandfather, grandmother, uncle_paternal, aunt_paternal, uncle_maternal, aunt_maternal, relative_other, friend, other."
          }
        },
        {
          "name": "Update beneficiary",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"full_name\": \"Saleh AlSaleh\",\n  \"age\": 73,\n  \"mobile\": \"0511112222\",\n  \"gender\": \"male\",\n  \"kinship\": \"father\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/me/beneficiaries/{{beneficiaryId}}", "host": ["{{baseUrl}}"], "path": ["api", "me", "beneficiaries", "{{beneficiaryId}}"] }
          }
        },
        {
          "name": "Delete beneficiary",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/me/beneficiaries/{{beneficiaryId}}", "host": ["{{baseUrl}}"], "path": ["api", "me", "beneficiaries", "{{beneficiaryId}}"] }
          }
        }
      ]
    },
    {
      "name": "Me - Health Conditions",
      "description": "Health conditions saved on the client's own profile.",
      "item": [
        {
          "name": "Get my health conditions",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/me/health-conditions", "host": ["{{baseUrl}}"], "path": ["api", "me", "health-conditions"] }
          }
        },
        {
          "name": "Set my health conditions",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"health_condition_ids\": [1, 2, 3]\n}" },
            "url": { "raw": "{{baseUrl}}/api/me/health-conditions", "host": ["{{baseUrl}}"], "path": ["api", "me", "health-conditions"] },
            "description": "Replaces the full set of saved health conditions for the client."
          }
        }
      ]
    },
    {
      "name": "Service Requests (Client)",
      "description": "Full lifecycle for service requests from the client's perspective.",
      "item": [
        {
          "name": "Create request",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"request_for\": \"self\",\n  \"service_type_id\": 1,\n  \"with_car\": true,\n  \"health_condition_ids\": [1],\n  \"location\": {\n    \"pickup\": { \"lat\": 24.7136, \"lng\": 46.6753 },\n    \"destination\": { \"lat\": 24.8000, \"lng\": 46.6500 }\n  }\n}" },
            "url": { "raw": "{{baseUrl}}/api/requests", "host": ["{{baseUrl}}"], "path": ["api", "requests"] },
            "description": "Creates a new request. Blocked with 409 ACTIVE_REQUEST_EXISTS if client already has a pending/accepted/in_progress request. For 'other', include beneficiary object."
          }
        },
        {
          "name": "List my requests",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/requests/me?page=1&limit=20", "host": ["{{baseUrl}}"], "path": ["api", "requests", "me"], "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "20" }, { "key": "status", "value": "completed", "disabled": true }] }
          }
        },
        {
          "name": "Get my active request",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/requests/me/active", "host": ["{{baseUrl}}"], "path": ["api", "requests", "me", "active"] },
            "description": "Returns the active request id + status + companion_id, or null. Used by the active-request banner."
          }
        },
        {
          "name": "Get my request",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/requests/me/{{requestId}}", "host": ["{{baseUrl}}"], "path": ["api", "requests", "me", "{{requestId}}"] }
          }
        },
        {
          "name": "List available companions",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/requests/{{requestId}}/available-companions?page=1&limit=20", "host": ["{{baseUrl}}"], "path": ["api", "requests", "{{requestId}}", "available-companions"], "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "20" }, { "key": "gender", "value": "male", "disabled": true }] }
          }
        },
        {
          "name": "Assign companion",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"companion_id\": {{companionId}}\n}" },
            "url": { "raw": "{{baseUrl}}/api/requests/{{requestId}}/assign-companion", "host": ["{{baseUrl}}"], "path": ["api", "requests", "{{requestId}}", "assign-companion"] }
          }
        },
        {
          "name": "Cancel request",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/requests/{{requestId}}/cancel", "host": ["{{baseUrl}}"], "path": ["api", "requests", "{{requestId}}", "cancel"] },
            "description": "Cancels the request. If already paid and companion accepted, triggers automatic refund."
          }
        },
        {
          "name": "Rate request",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"stars\": 5,\n  \"comment\": \"Excellent service\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/requests/{{requestId}}/rate", "host": ["{{baseUrl}}"], "path": ["api", "requests", "{{requestId}}", "rate"] }
          }
        },
        {
          "name": "Get my rating",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/requests/me/{{requestId}}/rating", "host": ["{{baseUrl}}"], "path": ["api", "requests", "me", "{{requestId}}", "rating"] }
          }
        }
      ]
    },
    {
      "name": "Payments (Client)",
      "description": "Moyasar checkout flow. Live + demo modes (admin toggleable).",
      "item": [
        {
          "name": "Start checkout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/payments/requests/{{requestId}}/checkout", "host": ["{{baseUrl}}"], "path": ["api", "payments", "requests", "{{requestId}}", "checkout"] },
            "description": "Starts a Moyasar invoice (live mode) or auto-marks paid (demo mode). Returns checkout URL when live."
          }
        },
        {
          "name": "Get my payment",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/payments/requests/{{requestId}}", "host": ["{{baseUrl}}"], "path": ["api", "payments", "requests", "{{requestId}}"] }
          }
        }
      ]
    },
    {
      "name": "Chat",
      "description": "Backend-only writes; reads go through Firestore directly from the client.",
      "item": [
        {
          "name": "Send message",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"text\": \"Hello, I will arrive in 10 minutes.\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/chats/{{requestId}}/messages", "host": ["{{baseUrl}}"], "path": ["api", "chats", "{{requestId}}", "messages"] },
            "description": "Posts a chat message. Backend writes to Firestore (clients cannot write directly per security rules)."
          }
        }
      ]
    },
    {
      "name": "Companion - Profile",
      "description": "Companion's own profile management.",
      "item": [
        {
          "name": "Get my profile",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/companions/me/profile", "host": ["{{baseUrl}}"], "path": ["api", "companions", "me", "profile"] }
          }
        },
        {
          "name": "Upsert profile",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"gender\": \"male\",\n  \"nationality\": \"Saudi\",\n  \"date_of_birth\": \"1988-03-22\",\n  \"city\": \"Riyadh\",\n  \"district\": \"Al Malqa\",\n  \"short_description\": \"Experienced caregiver with patience.\",\n  \"experience_summary\": \"5 years assisting elderly with medical visits.\",\n  \"health_status\": \"Healthy, non-smoker\",\n  \"has_car\": true\n}" },
            "url": { "raw": "{{baseUrl}}/api/companions/me/profile", "host": ["{{baseUrl}}"], "path": ["api", "companions", "me", "profile"] }
          }
        }
      ]
    },
    {
      "name": "Companion - Documents",
      "description": "Required documents for companion verification.",
      "item": [
        {
          "name": "List document types",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/companions/me/documents/types", "host": ["{{baseUrl}}"], "path": ["api", "companions", "me", "documents", "types"] },
            "description": "Returns the active document types the companion must upload (ID, selfie, IBAN, etc.)."
          }
        },
        {
          "name": "List my documents",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/companions/me/documents", "host": ["{{baseUrl}}"], "path": ["api", "companions", "me", "documents"] }
          }
        },
        {
          "name": "Upload document",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
